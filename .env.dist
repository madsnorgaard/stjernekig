# Stjernekig environment.
# Copy this file to .env and fill in real values (or keep the defaults for local dev).

# MySQL — used by the db container and read by Drupal via getenv() in settings.php
MYSQL_ROOT_PASSWORD=root
MYSQL_HOST=stjernekig_mysql
MYSQL_DATABASE=stjernekig_db
MYSQL_USER=stjernekig_dbusr
MYSQL_PASSWORD=stjernekig_dbpw

# Drupal
DRUPAL_HASH_SALT=replace-me-with-a-long-random-string

# Drush — used by `drush` inside the php container
DRUSH_OPTIONS_URI=http://stjernekig.docker

# NASA APOD API — get a real key at https://api.nasa.gov/ (DEMO_KEY is rate-limited)
NASA_API_KEY=DEMO_KEY
